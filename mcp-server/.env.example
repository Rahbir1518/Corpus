# Copy to .env and fill in. All optional — the server degrades gracefully:
#   - No Supabase  -> reads/writes the local seed graph (keyword recall)
#   - No OpenAI    -> keyword recall instead of vector search
#   - No Anthropic -> corpus_remember uses a heuristic splitter instead of Claude
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CORPUS_WORKSPACE=demo
EMBEDDING_MODEL=text-embedding-3-small
CLAUDE_MODEL=claude-haiku-4-5-20251001
