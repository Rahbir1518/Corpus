# Corpus dashboard — copy to .env.local and fill in. See ../REQUIREMENTS.md.
# Without Supabase env the dashboard renders from seed graph data instead of
# real memory, so it still boots for UI work.

# --- Supabase: server-side reads --------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase: browser client (Realtime) ------------------------------------
# NEXT_PUBLIC_* is exposed to the browser. Use the ANON key here, never the
# service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Auth0 (dashboard login) ------------------------------------------------
# Read by @auth0/nextjs-auth0. In the Auth0 app settings, add
# <APP_BASE_URL>/auth/callback as an Allowed Callback URL.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Generate with: openssl rand -hex 32
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000
