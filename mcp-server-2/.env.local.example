# Corpus v2 MCP server — copy to .env.local and fill in. ALL OPTIONAL.
# With none of these set the server runs in local mode: documents in
# ~/.corpus/<project>/, no keys, no network. See ../REQUIREMENTS.md.
#
# Real environment variables take precedence over this file.

# --- Team mode (Supabase) ---------------------------------------------------
# Both must be set, or the server silently falls back to local mode.
# Run supabase/documents.sql first. Service role key is server-side only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Identity ---------------------------------------------------------------
# Project id. Defaults to the working directory's folder name. Set explicitly
# so teammates with differently-named clones share the same memory.
# CORPUS_PROJECT=

# Label shown in the session ledger, e.g. claude-code / cursor / codex.
# CORPUS_AGENT=

# --- Code queries -----------------------------------------------------------
# Full path to the graphify binary, only if auto-detection fails (Windows: pip
# installs to a Scripts dir that is usually not on PATH).
# GRAPHIFY_PATH=

# NOTE: v2 makes no LLM calls. OPENAI_API_KEY, ANTHROPIC_API_KEY, EMBEDDING_MODEL,
# CLAUDE_MODEL and CORPUS_WORKSPACE were v1 settings and are read by nothing here.
