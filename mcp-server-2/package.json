{
  "name": "corpus-mcp-v2",
  "version": "0.1.0",
  "description": "Corpus v2 — markdown-first, local-first project memory for AI agents (MCP server). No DB, no API keys.",
  "type": "module",
  "bin": {
    "corpus-mcp-v2": "dist/index.js",
    "corpus-setup": "dist/setup.js",
    "corpus-connect": "dist/connect.js",
    "corpus-disconnect": "dist/disconnect.js",
    "corpus-status": "dist/status.js",
    "corpus-ls": "dist/ls.js",
    "corpus-hook": "dist/hooks.js"
  },
  "main": "dist/index.js",
  "files": ["dist", "README.md"],
  "engines": { "node": ">=18" },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "smoke": "tsx src/scripts/smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@supabase/supabase-js": "^2.75.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^20.0.0"
  }
}
